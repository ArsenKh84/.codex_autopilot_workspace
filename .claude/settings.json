{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"/Users/admin/Downloads/claude-code-setup/ai-agent/hooks/on_edit.sh\" \"$CLAUDE_FILE_PATH\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"/Users/admin/Downloads/claude-code-setup/ai-agent/hooks/on_bash.sh\" \"$CLAUDE_BASH_COMMAND\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"/Users/admin/Downloads/claude-code-setup/ai-agent/hooks/on_stop.sh\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true
  }
}
